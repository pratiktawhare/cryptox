# ─────────────────────────────────────────────────────────────
# CryptoX Server — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT (auto-generated on first run if left blank)
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Encryption (auto-generated on first run if left blank)
ENCRYPTION_KEY=

# AI API Keys
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=https://your-app.vercel.app

# Delta Exchange (defaults shown — only override if needed)
DELTA_BASE_URL=https://api.india.delta.exchange
DELTA_WS_URL=wss://public-socket.india.delta.exchange
